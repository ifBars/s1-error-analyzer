{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/ErrorAnalyzer.Core/ErrorAnalyzer.Core.csproj"
          ]
        }
      ],
      "dest": "api",
      "namespaceLayout": "Nested",
      "disableGitFeatures": true,
      "disableDefaultFilter": false,
      "shouldSkipMarkup": false,
      "force": true,
      "includePrivateMembers": false,
      "includeExplicitInterfaceImplementations": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/material"
    ],
    "postProcessors": [
      "ExtractSearchIndex"
    ],
    "globalMetadata": {
      "_appName": "ErrorAnalyzer.Core",
      "_appTitle": "ErrorAnalyzer.Core API Docs",
      "_enableSearch": true,
      "_navbarTitle": "ErrorAnalyzer.Core API Docs",
      "pdf": true
    }
  }
}
