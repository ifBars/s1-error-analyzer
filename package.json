{
  "name": "scheduleone-error-analyzer-workspace",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "src/scheduleone-error-analyzer"
  ],
  "scripts": {
    "restore:dotnet": "dotnet restore ErrorAnalyzer.sln",
    "dev": "bun scripts/run-frontend.mjs dev",
    "build": "bun scripts/run-frontend.mjs build",
    "build:pages": "bun scripts/run-frontend.mjs build:pages",
    "build:pages:site": "bun scripts/build-pages-site.mjs",
    "build:core-docs": "bun scripts/generate-core-docs.mjs",
    "lint": "bun scripts/run-frontend.mjs lint",
    "test": "dotnet test tests/ErrorAnalyzer.Core.Tests/ErrorAnalyzer.Core.Tests.csproj",
    "test:workspace": "dotnet test ErrorAnalyzer.sln"
  }
}
